# ----------------------------------------------------------------------------
# Mind & Health — plantilla de .env para PRODUCCIÓN
# Copia a .env en el servidor y completa los valores. NO subas este archivo lleno a git.
# ----------------------------------------------------------------------------

APP_NAME="Mind & Health"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Bogota
APP_URL=https://tudominio.co

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

# --- Base de datos (MySQL / MariaDB) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=health
DB_USERNAME=health
DB_PASSWORD=

# --- Sesión / caché / colas ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Correo (proveedor SMTP real: Brevo, Mailgun, SES...) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="citas@tudominio.co"
MAIL_FROM_NAME="${APP_NAME}"

# --- Mercado Pago (credenciales de PRODUCCIÓN) ---
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# --- Reglas de agendamiento (opcionales; tienen valores por defecto) ---
BOOKING_MIN_ANTICIPATION_HOURS=2
BOOKING_HORIZON_DAYS=30
BOOKING_HOLD_MINUTES=15
BOOKING_CANCEL_MIN_HOURS=24
BOOKING_REMINDER_HOURS_BEFORE=24
